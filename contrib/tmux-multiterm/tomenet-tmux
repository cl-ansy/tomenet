#!/bin/sh
#
# tomenet-tmux: launch tomenet in a tmux session with one pane per ang_term.
# Each pane gets its own pty; the game writes to all four directly via the
# --term=IDX:tty client args.
#
# Layout (default, hardcoded — edit below to change):
#
#   +---------------------+----------+
#   |                     | term-1   |   <- msg/chat
#   |                     +----------+
#   |   term-0 (main)     | term-2   |   <- inventory
#   |                     +----------+
#   |                     | term-3   |   <- recall/other
#   +---------------------+----------+
#
# Usage:
#   ./contrib/tmux-multiterm/tomenet-tmux [tomenet args...]
#
# Examples:
#   ./contrib/tmux-multiterm/tomenet-tmux
#   ./contrib/tmux-multiterm/tomenet-tmux -lMyChar mypass europe.tomenet.eu
#
# Notes:
#   - Keystrokes only register in the main pane (term 0). Side panes hold a
#     `sleep infinity` placeholder so their pty stays open; input there is lost.
#   - Detach with Ctrl-b d, reattach with `tmux attach -t tomenet-<pid>`.
#   - When the game exits, the tmux session is killed (cleaning up sleeps).

set -eu

# --- locate the binary --------------------------------------------------------

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
REPO_ROOT=$(cd "$SCRIPT_DIR/../.." && pwd)

if [ -x "$REPO_ROOT/tomenet" ]; then
    BIN="$REPO_ROOT/tomenet"
elif [ -x "$REPO_ROOT/src/tomenet" ]; then
    BIN="$REPO_ROOT/src/tomenet"
else
    echo "tomenet binary not found." >&2
    echo "Build it first: cd $REPO_ROOT/src && make tomenet" >&2
    exit 1
fi

command -v tmux >/dev/null 2>&1 || { echo "tmux not installed." >&2; exit 1; }

# --- session bring-up ---------------------------------------------------------

SESSION="tomenet-$$"

cleanup() {
    tmux kill-session -t "$SESSION" 2>/dev/null || true
}
trap 'rc=$?; cleanup; exit $rc' INT TERM

# Detached session sized to the current terminal. Sizes don't matter much because
# tmux will resize once we attach; what matters is that each pane has a tty.
COLS=$(tput cols 2>/dev/null || echo 240)
ROWS=$(tput lines 2>/dev/null || echo 60)
tmux new-session -d -s "$SESSION" -x "$COLS" -y "$ROWS"

PANE0=$(tmux list-panes -t "$SESSION" -F '#{pane_id}' | head -1)
TTY0=$(tmux display-message -p -t "$PANE0" '#{pane_tty}')

# Right column = 50% width.
PANE1=$(tmux split-window -h -p 50 -t "$PANE0" -P -F '#{pane_id}')
TTY1=$(tmux display-message -p -t "$PANE1" '#{pane_tty}')

# Split the right column into thirds (33/33/33).
PANE2=$(tmux split-window -v -p 67 -t "$PANE1" -P -F '#{pane_id}')
TTY2=$(tmux display-message -p -t "$PANE2" '#{pane_tty}')
PANE3=$(tmux split-window -v -p 50 -t "$PANE2" -P -F '#{pane_id}')
TTY3=$(tmux display-message -p -t "$PANE3" '#{pane_tty}')

# Park a placeholder in each side pane so its pty stays open and the shell
# prompt doesn't repaint over the game's drawing.
for p in "$PANE1" "$PANE2" "$PANE3"; do
    tmux send-keys -t "$p" 'exec sleep 999999999' Enter
done

# --- run the game in the main pane --------------------------------------------

# Quote each arg so spaces survive the trip through send-keys.
quoted=""
for a in "$@"; do
    esc=$(printf '%s' "$a" | sed "s/'/'\\\\''/g")
    quoted="$quoted '$esc'"
done

# -c forces the GCU (curses) interface even though the binary also has X11
# compiled in. `cd` so the binary finds lib/. After the game exits, kill the
# session so the placeholder sleeps in the side panes also die.
GAME_CMD="cd '$REPO_ROOT' && exec '$BIN' -c --term=0:$TTY0 --term=1:$TTY1 --term=2:$TTY2 --term=3:$TTY3$quoted"
tmux send-keys -t "$PANE0" "$GAME_CMD; tmux kill-session -t $SESSION" Enter

# Hand off to the user. exec replaces us, so the trap is no longer needed.
trap - INT TERM
exec tmux attach -t "$SESSION"
